// OneMoment — schema
// Tus invitados capturan el evento. La IA crea la película.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Un evento (boda, cumpleaños, etc.). Se comparte por QR/link.

model Event {
  id         String    @id @default(cuid())
  slug       String    @unique // usado en el link público /j/<slug>
  ownerToken String?   @unique // secreto del organizador: da acceso al panel /e/<id>
  ownerEmail String? // email del dueño: avisos + reclamo del evento a su cuenta
  // ── Paquete por tamaño de evento ──
  // plan/uploadLimit NULL = evento anterior al sistema de pagos: ilimitado y
  // sin marca de agua (grandfathered — no se le rompe nada a nadie).
  plan        String? // demo | p100 | p300 | p800 | custom
  uploadLimit Int? // tope de subidas del paquete (null = sin tope)
  paidCents   Int? // total pagado (para upgrades: se paga la diferencia)
  paidAt      DateTime?
  stripeSession String? // última sesión de checkout completada (idempotencia)
  userId     String? // cuenta dueña (null = evento legado, sólo owner-token)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String // "Boda de Barak & ..."
  type       String    @default("wedding") // wedding | birthday | corporate | ...
  date       DateTime?
  hostName   String? // quién organiza
  coverColor String    @default("#0f0f12")
  createdAt  DateTime  @default(now())

  // ── Muro en vivo ──
  // moderateWall: las subidas NUEVAS esperan aprobación del organizador antes
  // de aparecer en pantalla (eventos formales). wallCounter: contador de
  // "momentos capturados" en la esquina del muro (energía social).
  // wallCounter default false a nivel DB para que los eventos EXISTENTES no
  // cambien sin opt-in; los eventos nuevos nacen con true (app/api/events).
  moderateWall Boolean @default(false)
  wallCounter  Boolean @default(false)

  guests   Guest[]
  media    MediaItem[]
  reels    Reel[]
  tracks   Track[]
  missions Mission[]
  flashes  Flash[]

  @@index([userId])
  @@index([ownerEmail])
}

// Una pista de música subida para el evento (banda sonora de los reels).

model Track {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String // nombre legible (canción)
  filename  String // nombre en disco
  mimeType  String
  createdAt DateTime @default(now())

  @@index([eventId])
}

// Un invitado que sube contenido. Identificado por nombre + cookie/sesión, sin login.

model Guest {
  id        String   @id @default(cuid())
  name      String
  // Identidad invisible del invitado: UUID secreto guardado en su dispositivo
  // (localStorage + cookie 90 días). Da acceso SOLO a sus propias subidas y
  // SOLO en este evento. Null = invitado legado (antes del sistema de tokens).
  token     String?  @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  media MediaItem[]

  @@index([eventId])
}

// Misión de fotos: reto de subida que gamifica la captura ("selfie con alguien
// que no conoces"). Las define el organizador (con un set por defecto según el
// tipo de evento) y el invitado las completa subiendo con la misión activa.

model Mission {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  media MediaItem[]

  @@index([eventId])
}

// Momento Flash: el organizador aprieta un botón y TODOS los teléfonos
// conectados muestran "📸 ¡FOTO AHORA!". Las subidas de la ventana siguiente
// quedan etiquetadas con el flash. Puede haber varios por evento.

model Flash {
  id      String   @id @default(cuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firedAt DateTime @default(now())

  media MediaItem[]

  @@index([eventId])
}

// Una foto o video subido por un invitado.

model MediaItem {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestId String?
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  kind      String // "photo" | "video"
  filename  String // nombre en disco (storage)
  mimeType  String
  width     Int?
  height    Int?
  durationS Float? // duración en segundos (video)
  takenAt   DateTime? // timestamp de captura si está en metadata
  createdAt DateTime  @default(now())

  // ----- Capa de IA -----
  status       String  @default("pending") // pending | processing | scored | failed
  qualityScore Float? // 0..1 nitidez/exposición/composición
  isBlurry     Boolean @default(false)
  isDuplicate  Boolean @default(false)
  dupGroup     String? // hash perceptual / grupo de duplicados
  moment       String? // entrada | ceremonia | beso | baile | brindis | fiesta | ...
  hasFaces     Boolean @default(false)
  faceCount    Int     @default(0)
  focalX       Float? // centro de interés 0..1 (caras) para el encuadre 9:16
  focalY       Float?
  curatedAt    DateTime? // cuándo pasó por la curación IA de pago — NUNCA se repite
  audioMoments String? // JSON [{start,dur,kind,score}] — momentos de audio real (videos)
  caption      String? // descripción generada por IA
  selected     Boolean @default(false) // entró en el "mejor de"

  // ----- Anulación manual del dueño (gana sobre la IA) -----
  pinned Boolean @default(false) // forzar DENTRO de la película (aunque la IA no la eligiera)
  hidden Boolean @default(false) // forzar FUERA de la película (aunque la IA la eligiera)

  // ----- Fiesta en vivo -----
  // Misión que cumplió esta subida (null = subida libre) y flash al que llegó.
  missionId String?
  mission   Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  flashId   String?
  flash     Flash?   @relation(fields: [flashId], references: [id], onDelete: SetNull)
  // Moderación del muro: con moderateWall activo, lo nuevo nace en false y el
  // organizador lo aprueba desde el panel. Sin moderación todo nace aprobado.
  approved  Boolean  @default(true)

  @@index([eventId, status])
  @@index([eventId, moment])
}

// Una película/reel generado para el evento.

model Reel {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  format    String // "reel" (30s) | "trailer" (3min) | "film" (10min)
  status    String   @default("queued") // queued | rendering | done | failed
  outputUrl String?
  createdAt DateTime @default(now())

  @@index([eventId])
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  events        Event[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Salud del servicio y alertas ──
// Un incidente = algo que Itay debe saber (cuota agotada, backup fallido,
// render caído). El email crítico sale al instante; emailedAt null = el email
// no pudo salir y el banner del panel lo muestra como respaldo.
model Incident {
  id         String    @id @default(cuid())
  service    String // anthropic | rekognition | resend | stripe | disk | backup | render | digest
  severity   String // critical | warning
  title      String
  detail     String
  link       String? // página de facturación/dashboard del servicio
  createdAt  DateTime  @default(now())
  emailedAt  DateTime? // null = email falló o pendiente → banner de respaldo
  resolvedAt DateTime?

  @@index([service, createdAt])
  @@index([severity, emailedAt, resolvedAt])
}

// Contadores mensuales por servicio (para cuota de Resend y el resumen de
// gastos del día 1). service puede llevar el modelo: "anthropic:claude-haiku-4-5".
model UsageStat {
  id          String @id @default(cuid())
  service     String
  month       String // "2026-07"
  count       Int    @default(0)
  inputUnits  Int    @default(0) // tokens de entrada (anthropic) u otros
  outputUnits Int    @default(0) // tokens de salida

  @@unique([service, month])
}
